{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight",
  "model": "github-copilot/claude-opus-4.6",
  "mcp": {
    "Microsoft Learn MCP Server": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    }
  },
  "provider": {
    "ollamaLocal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:26b": {
          "name": "gemma4:26b"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss:20b"
        }
      }
    },
    "ollamaHome": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (jnimacstudio)",
      "options": {
        "baseURL": "http://192.168.199.246:11434/v1"
      },
      "models": {
        "gemma4:26b": {
          "name": "gemma4:26b"
        },
        "gemma4:31b": {
          "name": "gemma4:31b"
        },
        "gpt-oss:120b": {
          "name": "gpt-oss:120b"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss:20b"
        }
      }
    }
  }
}
